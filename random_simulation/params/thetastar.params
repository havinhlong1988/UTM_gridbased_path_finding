# ======================================================================
# Theta* master objective-pair planning parameters - v4
# ======================================================================

MODEL_FILE = "output/random_node_map/random_2d_node_riskmap_seed1.xyz"
OUTPUT_DIR = "output/thetastar_master_plan"

# ----------------------------------------------------------------------
# Route objectives
# ----------------------------------------------------------------------
# Normal master network endpoints should be DB and DK only.
# FLZ is emergency support, not a normal endpoint.
ROUTE_OBJECTIVE_PREFIXES = ["DB", "DK"]
EXCLUDE_ROUTE_OBJECTIVE_PREFIXES = ["RA", "FLZ"]
FLZ_AS_ROUTE_ENDPOINT = False

PAIR_MODE = "unordered"
SKIP_SAME_PREFIX = False
MAX_PAIR_DISTANCE_M = 0.0

# ----------------------------------------------------------------------
# Number of routes per pair
# ----------------------------------------------------------------------
# 2 means:
#   forward_main_01, forward_backup_01
#   forward_main_02, forward_backup_02
#   backward_main_01, backward_backup_01
#   backward_main_02, backward_backup_02
ROUTE_SETS_PER_DIRECTION = 4

# main_01 is fastest. main_02+ avoid previous main routes.
# Larger radius gives more separated / usually longer alternative main routes.
MAIN_ROUTE_AVOID_PREVIOUS_RADIUS_M_LIST = [250.0, 200.0, 150.0, 100.0, 50.0, 0.0]

# For secondary main routes, choose the longest successful candidate among the relaxed trials.
# Options: "longest" | "first_success"
ALTERNATIVE_MAIN_SELECTION_MODE = "longest"
ALLOW_MAIN_DUPLICATE_IF_FAILED = False

# ----------------------------------------------------------------------
# FLZ emergency safety attraction
# ----------------------------------------------------------------------
USE_FLZ_SAFETY_ATTRACTION = True
FLZ_SUPPORT_SIGMA_M = 800.0
FLZ_SAFETY_WEIGHT = 0.40
MIN_FLZ_SLOWNESS_FACTOR = 0.65
SAVE_FLZ_SUPPORT_COLUMNS = True

# ----------------------------------------------------------------------
# No-fly / flyable rule
# ----------------------------------------------------------------------
NOFLY_SLOWNESS_THRESHOLD = 10.0
NOFLY_SLOWNESS_VALUE = 10.0
FORCE_ROUTE_OBJECTIVES_FLYABLE = False

# ----------------------------------------------------------------------
# Theta* parameters passed directly to src/thetastar.py
# ----------------------------------------------------------------------
THETASTAR_ASTAR_FIRST_LOS_SMOOTH = True
THETASTAR_ALLOW_ANY_ANGLE = True
THETASTAR_PURE_ASTAR_DELEGATE = True
THETASTAR_LINE_OF_SIGHT_METHOD = "bresenham"
THETASTAR_BRESENHAM_CLEARANCE_CELLS = 1
THETASTAR_OUTPUT_SAMPLED_PATH = True
THETASTAR_LOS_STRAIGHT_PATH_FALLBACK = False
THETASTAR_POINT_CLEARANCE_M = 45.0
THETASTAR_LINE_OF_SIGHT_STEP_FACTOR = 0.5
THETASTAR_LOS_SMOOTH_MAX_LOOKAHEAD_NODES = 200
THETASTAR_EDGE_FALLBACK_TO_ASTAR = True
THETASTAR_HEURISTIC_WEIGHT = 1.08
THETASTAR_MAX_EXPANSIONS = 150000

# ----------------------------------------------------------------------
# Speed constraints
# ----------------------------------------------------------------------
SEARCH_BBOX_BUFFER_M = 1500.0
RETRY_FULL_MAP_IF_FAILED = True

# ----------------------------------------------------------------------
# Forward / backward / backup route constraints
# ----------------------------------------------------------------------
# Backup route must stay close to its own main route.
BACKUP_CORRIDOR_M_LIST = [50.0, 100.0, 150.0, 200.0, 250.0]
BACKUP_BLOCK_MAIN_RADIUS_M = 30.0
ENDPOINT_BUFFER_M = 150.0

# Backward routes try to avoid all forward main routes.
BACKWARD_AVOID_FORWARD_RADIUS_M_LIST = [200.0, 150.0, 100.0, 50.0, 0.0]
ALLOW_BACKUP_DUPLICATE_IF_FAILED = True

# ----------------------------------------------------------------------
# Plotting
# ----------------------------------------------------------------------
SAVE_PAIR_FIGURES = True
SAVE_OVERVIEW_FIGURE = True
PLOT_NODE_SIZE = 4.0
PLOT_ROUTE_LINEWIDTH = 1.2


# ----------------------------------------------------------------------
# Route node locking / overlap control
# ----------------------------------------------------------------------
ENABLE_ROUTE_NODE_LOCK = True
# Maximum percentage of non-terminal path nodes that may overlap with
# already accepted route nodes.
MAX_ROUTE_NODE_OVERLAP_PERCENT = 10.0
# 0.0 means only exactly same nodes are considered overlap/locked.
LOCK_NODE_RADIUS_M = 0.0
# Try hard blocking of locked nodes first, then relax and accept only if the
# final overlap percentage is below the limit.
STRICT_LOCK_BLOCK_FIRST = True

# Fancy plot font
PLOT_FONT_FAMILY = "DejaVu Serif"
PLOT_TITLE_FONT_SIZE = 16
PLOT_LABEL_FONT_SIZE = 13
PLOT_LEGEND_FONT_SIZE = 10
PLOT_TEXT_FONT_SIZE = 8


# ----------------------------------------------------------------------
# Pair-aware swarm traffic criterion
# ----------------------------------------------------------------------
# Avoid flying near DB/DK terminals that are not part of the current pair.
# Example: for DB01->DK02, routes avoid DB02, DK01, DK03... to reduce
# high-density swarm traffic around unrelated terminals.
USE_OTHER_DB_DK_TRAFFIC_AVOIDANCE = True
OTHER_TERMINAL_AVOID_PREFIXES = ["DB", "DK"]
OTHER_TERMINAL_AVOID_SIGMA_M = 450.0
OTHER_TERMINAL_AVOID_WEIGHT = 0.80
MAX_OTHER_TERMINAL_SLOWNESS_FACTOR = 2.50