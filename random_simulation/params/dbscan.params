# ======================================================================
# DBSCAN hit-count clustering parameters
# ======================================================================

# Input/output
THETA_OUTPUT_DIR = "output/thetastar_master_plan"
ROUTE_NODES_DIR = "output/thetastar_master_plan/route_nodes"
MODEL_FILE = "output/thetastar_master_plan/planning_model_with_flz_support.xyz"
OUTPUT_DIR = "output/thetastar_master_plan/clustering_hitcount"

# ----------------------------------------------------------------------
# Hit-count definition
# ----------------------------------------------------------------------
# hit_count = number of unique routes passing through a node.
# visit_count = raw number of rows/visits, also saved for diagnostics.

# ----------------------------------------------------------------------
# DBSCAN on high-hit nodes
# ----------------------------------------------------------------------
DBSCAN_EPS_M = 300
DBSCAN_MIN_SAMPLES = 10
DBSCAN_USE_HIT_COUNT_WEIGHT = True
MIN_HIT_COUNT_FOR_DBSCAN = 10

# ----------------------------------------------------------------------
# Candidate intermediate nodes
# ----------------------------------------------------------------------
CANDIDATE_TOP_K_PER_CLUSTER = 2
CANDIDATE_MIN_HIT_COUNT = 10
CANDIDATE_MIN_GRAPH_DEGREE = 2
CANDIDATE_EXCLUDE_LABEL_PREFIXES = ["DB", "DK", "RA"]
CANDIDATE_INCLUDE_HIGH_HIT_NOISE = True
HIGH_HIT_NOISE_PERCENTILE = 90.0
MAX_HIGH_HIT_NOISE_CANDIDATES = 20

# ----------------------------------------------------------------------
# Whole-area density + balanced area-based candidate optimization
# ----------------------------------------------------------------------
AREA_GRID_SIZE_M = 1000.0
AREA_BASE_CANDIDATES_PER_ACTIVE_AREA = 1
AREA_EXTRA_CANDIDATES_MAX = 2
AREA_MAX_CANDIDATES_PER_AREA = 3

# Keep candidates spatially separated.
CANDIDATE_MIN_SEPARATION_M = 300.0
CANDIDATE_RELAXED_MIN_SEPARATION_M = 180.0
ALLOW_RELAXED_AREA_SELECTION = True

# Candidate pool scoring
CANDIDATE_SCORE_HIT_WEIGHT = 0.60
CANDIDATE_SCORE_DEGREE_WEIGHT = 0.20
CANDIDATE_SCORE_PAIR_WEIGHT = 0.15
CANDIDATE_SCORE_CLUSTER_WEIGHT = 0.05

# ----------------------------------------------------------------------
# Density plot filtering
# ----------------------------------------------------------------------
# Figure 00 removes no-fly and zero-density nodes from display.
# The full CSV still keeps all nodes; the filtered CSV is also saved.
DENSITY_PLOT_REMOVE_NOFLY = True
DENSITY_PLOT_REMOVE_ZERO = True

# ----------------------------------------------------------------------
# Balanced colorbar
# ----------------------------------------------------------------------
# Percentile scaling prevents a few extreme values from making all nodes
# look the same color. Values above the percentile cap are drawn in purple.
COLORBAR_BALANCE_MODE = "percentile"     # percentile | max | fixed
COLORBAR_PERCENTILE_MAX = 95.0
COLORBAR_VMIN_MODE = "min_positive"      # min_positive | zero | percentile
COLORBAR_PERCENTILE_MIN = 1.0
COLORBAR_OVER_COLOR = "purple"
COLORBAR_UNDER_COLOR = "black"
COLORBAR_REVERSE = True

# ----------------------------------------------------------------------
# Plotting
# ----------------------------------------------------------------------
NOFLY_SLOWNESS_THRESHOLD = 10.0
PLOT_FONT_FAMILY = "DejaVu Serif"
PLOT_TITLE_SIZE = 16
PLOT_LABEL_SIZE = 12
PLOT_LEGEND_SIZE = 9
PLOT_DPI = 250
BASE_NODE_SIZE = 1.0
PLOT_SHOW_BASE_MODEL = False
HEATMAP_CMAP = "magma"
HEATMAP_ALPHA = 1.0
NORMAL_NODE_SIZE = 8.0
CANDIDATE_STAR_SIZE = 220.0
SYMBOL_EDGE_LINEWIDTH = 0.5
CANDIDATE_EDGE_LINEWIDTH = 1.0
PLOT_CANDIDATE_LABELS = False
PLOT_AREA_QUOTA_LABELS = False

# Edge density figure 01 colorbar and bold continuous-line control
EDGE_DENSITY_PLOT_REMOVE_ZERO = True
EDGE_LINEWIDTH_MIN = 1.50
EDGE_LINEWIDTH_MAX = 5.00
EDGE_ALPHA = 1.00
EDGE_LINEWIDTH_POWER = 0.50

EDGE_LINESTYLE = "solid"
EDGE_CAPSTYLE = "round"
EDGE_JOINSTYLE = "round"

# ----------------------------------------------------------------------
# Minor candidate option
# ----------------------------------------------------------------------
# Existing balanced candidates are treated as MAJOR candidates.
# Minor candidates use a lower hit-count threshold to capture weaker outer
# corridors and secondary intermediate nodes.
ENABLE_MINOR_CANDIDATES = True
MINOR_CANDIDATE_MIN_HIT_COUNT = 2
MINOR_CANDIDATE_MAX_HIT_COUNT = 6
MINOR_CANDIDATE_MIN_GRAPH_DEGREE = 2

# Minor candidate area quota. This is intentionally smaller than major quota.
MINOR_AREA_BASE_CANDIDATES_PER_ACTIVE_AREA = 1
MINOR_AREA_EXTRA_CANDIDATES_MAX = 1
MINOR_AREA_MAX_CANDIDATES_PER_AREA = 2

# Minor candidates must not be too close to major candidates or each other.
MINOR_CANDIDATE_MIN_SEPARATION_M = 250.0
MINOR_CANDIDATE_MIN_SEPARATION_FROM_MAJOR_M = 250.0
MINOR_CANDIDATE_RELAXED_MIN_SEPARATION_M = 150.0
MINOR_CANDIDATE_RELAXED_MIN_SEPARATION_FROM_MAJOR_M = 150.0
ALLOW_RELAXED_MINOR_SELECTION = True

# Minor candidate scoring
MINOR_CANDIDATE_SCORE_HIT_WEIGHT = 0.50
MINOR_CANDIDATE_SCORE_DEGREE_WEIGHT = 0.25
MINOR_CANDIDATE_SCORE_PAIR_WEIGHT = 0.20
MINOR_CANDIDATE_SCORE_CLUSTER_WEIGHT = 0.05

# Major/minor marker control
MAJOR_CANDIDATE_MARKER = "*"
MINOR_CANDIDATE_MARKER = "D"
MINOR_CANDIDATE_MARKER_SIZE = 25.0
MINOR_CANDIDATE_EDGE_LINEWIDTH = 0.15
